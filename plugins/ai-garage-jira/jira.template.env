# Jira extension — local configuration template
#
# Copy this file to one of the canonical paths and rename to `secrets.env`:
#   ~/.ai-dev-garage/secrets.env                  (global)
#   <project>/.ai-dev-garage/secrets.env          (project)
#
# Legacy paths are still read (with a deprecation warning on hit) but will
# be migrated to the canonical location on the next write:
#   ~/.config/ai-garage/jira.env                  (legacy global)
#   <project>/.config/ai-garage/jira.env          (legacy project)
#
# Never commit secrets.env / jira.env. This template is safe to commit.
# Precedence and parsing: skills/jira-item-fetcher/references/REFERENCE.md
#
# API token: https://support.atlassian.com/atlassian-account/docs/manage-api-tokens-for-your-atlassian-account/

JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_API_TOKEN=

# --- Optional / reserved for future extension keys (not all read by jira-item-fetcher yet) ---
# ATLASSIAN_API_TOKEN=     # alias for JIRA_API_TOKEN in some setups
# CONFLUENCE_API_TOKEN=    # last-resort fallback when both of the above are unset
# JIRA_USER_EMAIL=         # if a skill needs Basic auth or display context
# JIRA_TIMEOUT_SECONDS=30
